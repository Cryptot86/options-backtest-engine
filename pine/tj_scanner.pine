//@version=5
indicator("TJ 3-Line Premium Scanner", overlay=true)

// ============ INPUTS ============
useSellLine  = input.bool(true,  "Line 1/2: SELL PUT (5-day low / 2-SD dip in uptrend)")
useCallLine  = input.bool(true,  "Line 3: BUY CALL on fresh 10x100 bullish cross (ES/GC)")
useSellCall  = input.bool(true,  "Line 4: SELL CALL — 2-SD rally in downtrend (AUTO: NG/CL charts only)")
useRsiDiv    = input.bool(true,  "Line 5: RSI DIVERGENCE put (bonus, rare — STOCKS ONLY)")
useStraddle  = input.bool(true,  "Line 6: STRADDLE DAY light — cheap vol (buy ATM straddle; ES/stocks)")
showTable    = input.bool(true,  "Show status table")
dteDays      = input.int(40, "Target DTE for 16Δ strike estimate", minval=20, maxval=60)
posClosed    = input.bool(false, "☑ I closed my position (reset tracker)")
armFrom      = input.time(timestamp("2025-01-01"), "Track positions from date (ignore older history)")

// ============ PRICE STRUCTURE (your indicators) ============
ema10  = ta.ema(close, 10)
ema100 = ta.ema(close, 100)
trendUp = ema10 > ema100
freshCross = trendUp and not trendUp[1]              // 10x100 bullish cross

basis = ta.sma(close, 20)
dev2  = 2.0 * ta.stdev(close, 20)
bbLower = basis - dev2
dip2SD  = close <= bbLower and trendUp               // 2-SD dip in uptrend
low5    = close <= ta.lowest(close, 5) and trendUp   // 5-day low in uptrend
bbUpper = basis + dev2
// SELL CALL is validated ONLY on NG/CL futures -> symbol-aware: the signal
// cannot exist on any other chart (no memory required).
isNGCL   = syminfo.root == "NG" or syminfo.root == "CL"
rally2SD = close >= bbUpper and not trendUp and isNGCL

// --- Line 5: RSI bullish divergence (price LL, RSI HL, uptrend) — bonus line
rsi14 = ta.rsi(close, 14)
pl    = ta.pivotlow(close, 3, 3)                     // confirmed price pivot low (3 bars later)
var float prevPL  = na
var float prevRSI = na
var float curPL   = na
var float curRSI  = na
if not na(pl)
    prevPL  := curPL
    prevRSI := curRSI
    curPL   := pl
    curRSI  := rsi14[3]
rsiDivRaw = not na(pl) and not na(prevPL) and curPL < prevPL and curRSI > prevRSI and trendUp
isStock   = syminfo.type == "stock"                 // futures/forex/crypto: signal cannot exist

// ============ GATE: VOL GATE (VIX 3-green, validated spec) ============
vix   = request.security("CBOE:VIX",   "D", close)
vixRank  = ta.percentrank(vix, 252)
spyC     = request.security("AMEX:SPY", "D", close)
hv20     = ta.stdev(math.log(spyC / spyC[1]), 20) * math.sqrt(252) * 100
gRich    = vixRank >= 50
gPaid    = vix > hv20
gStable  = vix <= vix[5]
gateGreen = gRich and gPaid and gStable
// Line 6: INVERSE gate — vol cheap => long-vol sleeve (buy ATM straddle 40DTE, +50%/-40%/21DTE)
cheapDay  = useStraddle and vixRank <= 30 and vix < hv20
var int stCount = 0
if cheapDay and not cheapDay[1]
    stCount += 1
rsiDivSig = useRsiDiv and rsiDivRaw and gateGreen and isStock   // line 5 (stocks only)

// ============ SIGNALS ============
// Gate applies to STOCKS (validated: -$21 ungated -> +$88 gated). The ES/MES
// futures put line was validated UNGATED (+$4,554 OOS) — matching the sim.
needGate   = syminfo.type == "stock"
gateOK     = needGate ? gateGreen : true
sellSignal = useSellLine and gateOK and (dip2SD or low5)
callSignal = useCallLine and freshCross
sellCallSig = useSellCall and rally2SD    // NG/CL only; IV gate lives in dashboard — verify before entry

volUse = math.max(vix, hv20) / 100.0
k16put = close * (1 - 0.994 * volUse * math.sqrt(dteDays / 365.0))

// ============ POSITION TRACKER (one-at-a-time, per your sizing rule) ============
// Records the FIRST sell signal while flat; time-exit = entry + (dteDays-21) days.
var bool  inPos      = false
var float posStrike  = na
var float posSpot    = na
var int   posEntryT  = na
holdCal = dteDays - 21                                  // calendar days until 21-DTE exit
if posClosed
    inPos := false
if sellSignal and not inPos and not posClosed and time >= armFrom
    inPos     := true
    posStrike := k16put
    posSpot   := close
    posEntryT := int(time)
daysHeld  = inPos ? math.round((time - posEntryT) / 86400000.0) : 0
daysLeft  = inPos ? math.max(holdCal - daysHeld, 0) : 0
timeExit  = inPos and daysHeld >= holdCal
breached  = inPos and close < posStrike

// ---- HISTORY COUNTERS (price-based estimate: win if price >= sold strike at exit)
var int totTrades = 0
var int totWins   = 0
if timeExit
    totTrades += 1
    if close >= posStrike
        totWins += 1
    inPos := false          // auto-cycle: tracker frees itself for the next signal

// exit-state message: the anti-panic script (from the backtest evidence)
posState = not inPos ? "flat — take next signal" :
     timeExit ? "⏰ TIME EXIT TODAY — close at market (21 DTE rule)" :
     breached ? "⚠️ strike breached — rules say HOLD to 21 DTE (stops lose: −$27K vs −$49K tested)" :
     close < posSpot ? "📉 underwater — NORMAL. Median winner dipped first. HOLD." :
     daysHeld >= 8 ? "🎯 check broker: 50% target likely near" :
     "✅ HOLD — collecting decay (" + str.tostring(daysLeft) + "d to time exit)"

// sold-strike line while in position
plot(inPos ? posStrike : na, "Sold strike", color=color.new(color.yellow, 0),
     linewidth=2, style=plot.style_linebr)

// ============ CHART: EMA cloud (green=up, red=down) ============
p10  = plot(ema10,  "EMA10",  color=color.new(color.blue, 0),  linewidth=2)
p100 = plot(ema100, "EMA100", color=color.new(color.orange, 0), linewidth=2)
fill(p10, p100, color = trendUp ? color.new(color.green, 78) : color.new(color.red, 78))
plot(bbLower, "BB -2SD", color=color.new(color.red, 40))

sell2SD = sellSignal and dip2SD
sell5DL = sellSignal and low5 and not dip2SD
plotshape(sell2SD, "SELL PUT (2SD)", shape.triangleup, location.belowbar,
     color.new(color.lime, 0), size=size.small, text="SELL PUT\n2-SD", textcolor=color.lime)
plotshape(sell5DL, "SELL PUT (5DL)", shape.triangleup, location.belowbar,
     color.new(color.green, 0), size=size.small, text="SELL PUT\n5-day low", textcolor=color.green)
plotshape(callSignal, "BUY CALL", shape.diamond, location.belowbar,
     color.new(color.aqua, 0), size=size.small, text="BUY CALL", textcolor=color.aqua)
plotshape(sellCallSig, "SELL CALL (NG/CL)", shape.triangledown, location.abovebar,
     color.new(color.red, 0), size=size.small, text="SELL CALL\n(check IV gate)", textcolor=color.red)
plotshape(rsiDivSig, "RSI DIV put (bonus)", shape.labelup, location.belowbar,
     color.new(color.fuchsia, 0), size=size.tiny, text="RSI DIV\nSELL PUT", textcolor=color.white)
plotshape(cheapDay and not cheapDay[1], "STRADDLE DAY", shape.circle, location.abovebar,
     color.new(color.purple, 0), size=size.tiny, text="STRADDLE\nvol cheap", textcolor=color.purple)

// ============ STATUS TABLE (high-contrast) ============
var table tb = table.new(position.top_right, 2, 10, border_width=1,
     border_color=color.new(color.white, 60))
if showTable and barstate.islast
    cHdr = color.rgb(103, 58, 183)
    cOk  = color.rgb(27, 94, 32)
    cNo  = color.rgb(155, 28, 28)
    cWn  = color.rgb(176, 122, 6)
    cRow = color.rgb(38, 45, 60)
    wht  = color.white
    table.cell(tb, 0, 0, "TJ SCANNER",     bgcolor=cHdr, text_color=wht)
    table.cell(tb, 1, 0, syminfo.ticker,   bgcolor=cHdr, text_color=wht)
    table.cell(tb, 0, 1, "VIX gate",       bgcolor=cRow, text_color=wht)
    table.cell(tb, 1, 1, (gRich ? "🟢" : "🔴") + (gPaid ? "🟢" : "🔴") + (gStable ? "🟢" : "🔴")
         + (gateGreen ? "  OPEN" : "  CLOSED"), bgcolor=gateGreen ? cOk : cNo, text_color=wht)
    table.cell(tb, 0, 2, "Trend (10x100)", bgcolor=cRow, text_color=wht)
    table.cell(tb, 1, 2, trendUp ? "UP — puts allowed" : "DOWN — no puts",
         bgcolor=trendUp ? cOk : cNo, text_color=wht)
    trig = dip2SD ? "2-SD dip" : low5 ? "5-day low" : ""
    sellState = not useSellLine ? "off" :
         inPos ? "⛔ position open — skip new signals" :
         sellSignal ? "✅ READY (" + trig + ") — sell tomorrow 9:30" :
         (dip2SD or low5) and needGate ? trig + " fired, gate CLOSED" : "waiting"
    table.cell(tb, 0, 3, "SELL PUT line",  bgcolor=cRow, text_color=wht)
    table.cell(tb, 1, 3, sellState, bgcolor=sellSignal and not inPos ? cOk : cRow, text_color=wht)
    table.cell(tb, 0, 4, "BUY CALL line",  bgcolor=cRow, text_color=wht)
    table.cell(tb, 1, 4, callSignal ? "✅ fresh cross — buy tomorrow" : "waiting",
         bgcolor=callSignal ? cOk : cRow, text_color=wht)
    // POSITION / EXIT DISCIPLINE row
    table.cell(tb, 0, 5, inPos ? "POSITION (day " + str.tostring(daysHeld) + ")" : "Position",
         bgcolor=cRow, text_color=wht)
    table.cell(tb, 1, 5, posState,
         bgcolor=timeExit ? cNo : breached ? cWn : inPos ? cOk : cRow, text_color=wht)
    cushion   = inPos ? close - posStrike : close - k16put
    cushionPc = 100.0 * cushion / close
    table.cell(tb, 0, 6, inPos ? "Strike / cushion" : "Est. 16Δ strike / cushion", bgcolor=cRow, text_color=wht)
    table.cell(tb, 1, 6, str.tostring(inPos ? posStrike : k16put, format.mintick)
         + "  (" + (cushion >= 0 ? "+" : "") + str.tostring(cushion, format.mintick)
         + " / " + str.tostring(cushionPc, "#.0") + "%)",
         bgcolor=cushion >= 0 ? cRow : cWn, text_color=wht)
    table.cell(tb, 0, 7, "Exit rules",     bgcolor=cRow, text_color=wht)
    table.cell(tb, 1, 7, "50% profit OR 21 DTE · NO price stops", bgcolor=cRow, text_color=wht)
    table.cell(tb, 0, 9, "STRADDLE (Sleeve 3)", bgcolor=cRow, text_color=wht)
    table.cell(tb, 1, 9, (cheapDay ? "🟣 VIX CHEAP — buy ATM straddle" : "VIX not cheap — off")
         + "  ·  " + str.tostring(stCount) + " signals (P&L: dashboard)",
         bgcolor=cheapDay ? color.rgb(90, 40, 140) : cRow, text_color=wht)
    winPct = totTrades > 0 ? 100.0 * totWins / totTrades : 0.0
    table.cell(tb, 0, 8, "History (this chart)", bgcolor=cRow, text_color=wht)
    table.cell(tb, 1, 8, str.tostring(totTrades) + " trades · " + str.tostring(totWins)
         + "W / " + str.tostring(totTrades - totWins) + "L · "
         + str.tostring(winPct, "#.0") + "% (price-based est.)",
         bgcolor=cRow, text_color=wht)

// ============ ALERTS ============
alertcondition(sellSignal and dip2SD, "TJ: SELL PUT (2-SD dip)", "Gate green + 2-SD dip: sell 16d put tomorrow")
alertcondition(sellSignal and low5 and not dip2SD, "TJ: SELL PUT (5-day low)", "Gate green + 5-day low: sell 16d put tomorrow")
alertcondition(callSignal, "TJ: BUY CALL signal", "Fresh 10x100 bullish cross: buy ATM call tomorrow")
alertcondition(sellCallSig, "TJ: SELL CALL (NG/CL)", "2-SD rally in downtrend on NG/CL: sell 16d call tomorrow IF dashboard IV gate is green")
alertcondition(rsiDivSig, "TJ: RSI DIVERGENCE (bonus put)", "RSI bullish divergence + gate green: sell 16d put tomorrow (rare, 90% historical win)")
alertcondition(cheapDay and not cheapDay[1], "TJ: STRADDLE DAY (vol cheap)",
     "Vol cheap (rank<=30 & IV<realized): buy ATM 40DTE straddle — exits +50%/-40%/21DTE (ES/stocks/CL only, never GC/NG)")
alertcondition(timeExit,   "TJ: TIME EXIT (21 DTE)", "Close the short put today — 21 DTE rule")
alertcondition(breached and not breached[1], "TJ: strike breached",
     "Strike breached — rules: HOLD to 21 DTE, no panic exit (tested: stops doubled losses)")
